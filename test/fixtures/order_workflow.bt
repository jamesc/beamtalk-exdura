/// Test workflow demonstrating query handler registration (BT-1503).
///
/// Registers query handlers via registerQueries: and updates workflow
/// state via the context at each step. Used by QueryTest to verify
/// query results reflect the last safe-point state.
///
///   engine startWorkflow: OrderWorkflow id: "wf-1" args: #("order-42")
Workflow subclass: OrderWorkflow

  /// Register query handlers for order status and full order info.
  class registerQueries: ctx =>
    ctx setState: #status to: "pending";
      setState: #orderId to: "";
      onQuery: "getStatus" do: [:snap | snap status]
    ctx onQuery: "getOrder" do: [:snap |
      #{#orderId => snap orderId, #status => snap status}
    ]

  /// Process an order: set status through stages with activities between.
  class run: orderId ctx: ctx =>
    ctx setState: #orderId to: orderId; setState: #status to: "processing"
    ctx
      runActivity: TestActivities
      method: #doubleIt:
      with: #(42)
    ctx setState: #status to: "completed"
    #{#orderId => orderId, #status => "completed"}
