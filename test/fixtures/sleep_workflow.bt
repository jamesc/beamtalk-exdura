/// Workflow that sleeps between two activity calls (BT-1494).
///
/// Used to test durable sleep recording and replay behavior.
/// Calls CountingActivity, sleeps, then calls CountingActivity again.
///
///   engine startWorkflow: SleepWorkflow id: "wf-1" args: #("hello")
Workflow subclass: SleepWorkflow

  /// Run two activities with a sleep in between.
  class run: input ctx: ctx -> Dictionary =>
    args := (input isKindOf: Dictionary) ifTrue: [input] ifFalse: [#{#input => input}]
    a := ctx
      runActivity: CountingActivity
      method: #doWork:
      with: #(args)
    ctx sleep: 50
    b := ctx
      runActivity: CountingActivity
      method: #doWork:
      with: #(args merge: #{#input => (a at: #result)})
    #{#first => a, #second => b}
