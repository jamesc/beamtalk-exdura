/// Test workflow with query handlers and a sleep between activities (BT-1503).
///
/// Used to test that queries during mid-execution return the last
/// safe-point state. The sleep provides a window to query while the
/// workflow is blocked.
///
///   engine startWorkflow: SlowOrderWorkflow id: "wf-1" args: #("order-42")
Workflow subclass: SlowOrderWorkflow

  /// Register query handlers for status and full order info.
  registerQueries: ctx =>
    ctx setState: #status to: "pending"
    ctx setState: #orderId to: ""
    ctx onQuery: "getStatus" do: [:snap | snap status]
    ctx onQuery: "getOrder" do: [:snap |
      #{#orderId => snap orderId, #status => snap status}
    ]

  /// Process an order with a sleep between activity calls.
  run: orderId ctx: ctx =>
    ctx setState: #orderId to: orderId
    ctx setState: #status to: "processing"
    ctx
      runActivity: TestActivities
      method: #doubleIt:
      with: #(42)
    // Sleep to provide a window for mid-execution queries
    ctx sleep: 3000
    ctx setState: #status to: "completed"
    #{#orderId => orderId, #status => "completed"}
