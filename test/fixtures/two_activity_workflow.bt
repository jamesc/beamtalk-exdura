/// Test workflow that runs two activities (BT-1492).
///
/// Used by WorkflowEngineTest to verify activity dispatch, event recording,
/// and replay behavior.
///
///   engine startWorkflow: TwoActivityWorkflow id: "wf-1" args: #(5)
///   // Runs doubleIt(5) => 10, then addNumbers(10, 10) => 20
Workflow subclass: TwoActivityWorkflow

  /// Run two activities: double the input, then add the result to itself.
  class run: input ctx: ctx -> Integer =>
    doubled := ctx
      runActivity: TestActivities
      method: #doubleIt:
      with: #(input)
    ctx
      runActivity: TestActivities
      method: #addNumbers:
      with: #(#{#a => doubled, #b => doubled})
