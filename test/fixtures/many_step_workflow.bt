/// Test workflow that runs many activities in sequence (BT-1505).
///
/// Used by SnapshotTest to verify snapshot creation and replay optimization.
/// Runs N activities (configurable via input), accumulating results.
///
///   engine startWorkflow: ManyStepWorkflow id: "wf-1" args: #(#{#input => 120})
Workflow subclass: ManyStepWorkflow

  /// Recursive helper: run activities from `from` to `count`, accumulating total.
  class runSteps: count :: Integer from: idx :: Integer total: acc :: Integer ctx: ctx args: args :: Dictionary -> Integer =>
    idx > count ifTrue: [^acc]
    ctx
      runActivity: CountingActivity
      method: #doWork:
      with: #(args merge: #{#input => idx asString})
    self
      runSteps: count
      from: idx + 1
      total: acc + 1
      ctx: ctx
      args: args

  /// Run N sequential activities, accumulating a running total.
  /// Input may be an Integer (legacy) or a Dictionary with #input key.
  /// Uses class helper to avoid block mutation gotcha with activity calls.
  class run: input ctx: ctx -> Integer =>
    args := (input isKindOf: Dictionary) ifTrue: [
      input
    ] ifFalse: [#{#input => input}]
    count := args at: #input
    ManyStepWorkflow
      runSteps: count
      from: 1
      total: 0
      ctx: ctx
      args: args
