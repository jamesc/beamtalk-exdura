// BT-1496: BUnit tests for file-backed EventStore (append-only ETF persistence).
//
// Tests verify:
// - Events are written to disk as ETF on append
// - On EventStore startup, events are reloaded from disk files
// - ETF serialization handles all Exdura data types
// - Corrupt file handling (graceful recovery)
//
// Note: restart tests pre-populate ETF files in setUp and verify the store
// loads them correctly, rather than doing stop+respawn within a single test
// (which is fragile due to named ETS table lifecycle timing).

TestCase subclass: EventStorePersistenceTest
  field: store = nil
  field: testDir = "target/bt-test-tmp/event-store-persist"

  setUp =>
    // Clean up any leftover ETS tables and test directory
    (Erlang ets whereis: #exdura_executions) =:= #undefined ifFalse: [
      (Ets named: #exdura_executions) delete
    ]
    (Erlang ets whereis: #exdura_events) =:= #undefined ifFalse: [
      (Ets named: #exdura_events) delete
    ]
    (File isDirectory: self.testDir) ifTrue: [
      [File deleteAll: self.testDir] on: Error do: [:e | nil]
    ]
    self.store := EventStore spawnWith: #{#dataDir => self.testDir}
    self

  tearDown =>
    self.store isNil
      ifFalse: [
        [self.store destroy] on: Error do: [:e | nil]
        [self.store stop] on: Error do: [:e | nil]
      ]
    self.store := nil
    (Erlang ets whereis: #exdura_executions) =:= #undefined ifFalse: [
      (Ets named: #exdura_executions) delete
    ]
    (Erlang ets whereis: #exdura_events) =:= #undefined ifFalse: [
      (Ets named: #exdura_events) delete
    ]
    (File isDirectory: self.testDir) ifTrue: [
      [File deleteAll: self.testDir] on: Error do: [:e | nil]
    ]

  // --- Helper: write ETF event data directly to disk ---

  /// Write an event dictionary as ETF binary to a workflow's event file.
  /// Used to pre-populate files for reload tests.
  writeEtfEvent: workflowId :: String event: evtDict :: Dictionary =>
    path := self.testDir ++ "/events/{workflowId}.etf"
    bin := Binary serialize: evtDict
    File appendBinary: path contents: bin

  // --- Directory creation ---
  testDirectoriesCreatedOnInitialize =>
    self assert: (File isDirectory: self.testDir ++ "/events")
    self assert: (File isDirectory: self.testDir ++ "/snapshots")

  // --- Events written to disk on append ---
  testEventsWrittenToDisk =>
    evt := ExduraEvent new: #{
      #eventType => #WorkflowStarted,
      #timestamp => 100,
      #payload => #{}
    }
    self.store appendEvents: "wf-disk-1" events: #(evt)
    self assert: (File exists: self.testDir ++ "/events/wf-disk-1.etf")

  testMultipleAppendsCreateAppendOnlyFile =>
    evt1 := ExduraEvent new: #{
      #eventType => #WorkflowStarted,
      #timestamp => 100,
      #payload => #{}
    }
    evt2 := ExduraEvent
      new: #{
        #eventType => #ActivityScheduled,
        #timestamp => 200,
        #payload => #{#activityType => "DoWork"}
      }
    self.store appendEvents: "wf-append" events: #(evt1)
    self.store appendEvents: "wf-append" events: #(evt2)
    events := self.store readEvents: "wf-append" fromSeq: 1
    self assert: events size equals: 2
    self assert: (events at: 1) eventId equals: 1
    self assert: (events at: 2) eventId equals: 2

  testAppendEmptyEventsNoFile =>
    self.store appendEvents: "wf-noop" events: #()
    self deny: (File exists: self.testDir ++ "/events/wf-noop.etf")

  testEtfFileContainsValidData =>
    // Append an event and verify the file contains valid ETF
    evt := ExduraEvent
      new: #{
        #eventType => #WorkflowStarted,
        #timestamp => 12345,
        #payload => #{#key => "value"}
      }
    self.store appendEvents: "wf-etf-valid" events: #(evt)
    // Read the file back and verify contents
    content := (File readBinary: (self.testDir ++ "/events/wf-etf-valid.etf")) unwrap
    dict := Binary deserialize: content
    @expect type
    self assert: (dict at: #eventId) equals: 1
    @expect type
    self assert: (dict at: #eventType) equals: #WorkflowStarted
    @expect type
    self assert: (dict at: #timestamp) equals: 12345
    @expect type
    self assert: ((dict at: #payload) at: #key) equals: "value"

  testMultipleEventsInSingleFile =>
    // Append multiple events and verify they're all in the same file
    self.store
      appendEvents: "wf-multi"
      events: #(ExduraEvent new: #{
        #eventType => #WorkflowStarted,
        #timestamp => 100,
        #payload => #{}
      }, ExduraEvent new: #{
        #eventType => #ActivityScheduled,
        #timestamp => 200,
        #payload => #{}
      })
    self.store
      appendEvents: "wf-multi"
      events: #(ExduraEvent new: #{
        #eventType => #ActivityCompleted,
        #timestamp => 300,
        #payload => #{}
      })
    // Parse the file directly to verify all 3 events are there
    content := (File readBinary: (self.testDir ++ "/events/wf-multi.etf")) unwrap
    events := EventStore
      parseEtfBinary: content
      offset: 0
      size: (Binary size: content)
      acc: #()
    self assert: events size equals: 3
    self assert: (events at: 1) eventId equals: 1
    self assert: (events at: 2) eventId equals: 2
    self assert: (events at: 3) eventId equals: 3

  // --- destroyWithFiles cleans up ---
  testDestroyWithFilesRemovesDirectory =>
    self.store
      appendEvents: "wf-cleanup"
      events: #(ExduraEvent new: #{
        #eventType => #WorkflowStarted,
        #timestamp => 100,
        #payload => #{}
      })
    self assert: (File exists: self.testDir ++ "/events/wf-cleanup.etf")
    self.store destroyWithFiles
    [self.store stop] on: Error do: [:e | nil]
    self.store := nil
    self deny: (File isDirectory: self.testDir)
