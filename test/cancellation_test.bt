/// BT-1508: BUnit tests for cancellation propagation.
///
/// Tests that workflows can be cancelled via the client, CancellationError
/// is raised and catchable for compensation, pending activities are cancelled,
/// and child workflows are cancelled per parent-close policy.
///
/// Fixtures: test/fixtures/cancellable_order_workflow.bt, test/fixtures/cancellable_parent_workflow.bt,
///           test/fixtures/cancellation_activities.bt, test/fixtures/slow_workflow.bt
TestCase subclass: CancellationTest
  field: client = nil
  field: store = nil
  field: engine = nil

  setUp =>
    self.client := ExduraClient connect: #{
      #dataDir => "_build/bt-test-tmp/cancellation"
    }
    self.engine := self.client engine
    self.store := self.client eventStore
    self

  tearDown =>
    self.engine isNil ifFalse: [[self.engine stop] on: Error do: [:e | nil]]
    self.client isNil
      ifFalse: [
        [self.client destroy] on: Error do: [:e | nil]
        [self.client stop] on: Error do: [:e | nil]
      ]
    self.client := nil
    self.engine := nil
    self.store := nil

  /// Poll for a ChildWorkflowStarted event in the parent's history.
  awaitChildStarted: parentId :: String timeout: timeoutMs :: Integer -> ExduraEvent =>
    deadline := Time nowMs + timeoutMs
    [true]
      whileTrue: [
        events := self.store readEvents: parentId fromSeq: 1
        childStarted := events select: [:e |
          e eventType =:= #ChildWorkflowStarted
        ]
        childStarted size > 0 ifTrue: [^childStarted at: 1]
        Time nowMs >= deadline ifTrue: [
          self error: "Timed out waiting for child of {parentId}"
        ]
        Timer sleep: 50
      ]
    self error: "unreachable"

  /// Poll for a workflow to reach a terminal status.
  awaitWorkflow: workflowId timeout: timeoutMs :: Integer =>
    deadline := Time nowMs + timeoutMs
    [true]
      whileTrue: [
        exec := self.store getExecution: workflowId
        (exec isNil not
          and: [
            exec status =:= #completed or: [
              exec status =:= #failed or: [exec status =:= #cancelled]
            ]
          ]) ifTrue: [^exec]
        Time nowMs >= deadline ifTrue: [
          self error: "Timed out waiting for {workflowId}"
        ]
        Timer sleep: 50
      ]

  // === client cancel: cancels a running workflow ===
  testClientCancelCancelsRunningWorkflow =>
    _handle := self.client
      start: SlowWorkflow
      id: "cancel-basic-1"
      args: #(2000)
      taskQueue: "default"
      options: #{}

    // Wait for workflow to start running
    Erlang timer sleep: 500

    // Verify it's running
    exec := self.store getExecution: "cancel-basic-1"
    self assert: exec status equals: #running

    // Cancel — engine is free (timer runs in context, not engine)
    self.engine cancelWorkflow: "cancel-basic-1"

    // Wait for cancellation to take effect
    Erlang timer sleep: 500

    // Verify it's cancelled
    exec2 := self.store getExecution: "cancel-basic-1"
    self assert: exec2 status equals: #cancelled

    // Verify WorkflowCancelled event was recorded
    events := self.store readEvents: "cancel-basic-1" fromSeq: 1
    eventTypes := events collect: [:e | e eventType]
    self assert: (eventTypes includes: #WorkflowCancelled)

  // === Workflow receives CancellationError, can handle with on:do: ===
  testCancellationWithCompensation =>
    _handle := self.client
      start: CancellableOrderWorkflow
      id: "cancel-comp-1"
      args: #("order-42")
      taskQueue: "default"
      options: #{}

    // Wait for the first activity (quickTask) to complete and
    // the second activity (longTask) to start
    Erlang timer sleep: 500

    // Verify it's running and processing
    exec := self.store getExecution: "cancel-comp-1"
    self assert: exec status equals: #running

    // Cancel the workflow
    self.engine cancelWorkflow: "cancel-comp-1"

    // Wait for cancellation to complete
    self awaitWorkflow: "cancel-comp-1" timeout: 10000

    // Verify event history includes cancellation
    events := self.store readEvents: "cancel-comp-1" fromSeq: 1
    eventTypes := events collect: [:e | e eventType]
    self assert: (eventTypes includes: #WorkflowCancelled)

  // === Cancellation propagates to child workflows ===
  testCancellationPropagatesToChildWorkflows =>
    self.engine
      startWorkflow: CancellableParentWorkflow
      id: "cancel-parent-1"
      args: #(5)

    // Poll for the child to be started (runner must execute and call engine)
    childStartedEvent := self awaitChildStarted: "cancel-parent-1" timeout: 10000
    childId := childStartedEvent payload at: #childWorkflowId

    // Cancel the parent — engine is free to process immediately
    self.engine cancelWorkflow: "cancel-parent-1"

    // Wait for cancellation to propagate
    Erlang timer sleep: 500

    // Verify parent is cancelled
    parentExec := self.store getExecution: "cancel-parent-1"
    self assert: parentExec status equals: #cancelled

    // Verify child is also cancelled (default #terminate policy)
    childExec2 := self.store getExecution: childId
    self assert: childExec2 status equals: #cancelled

    // Verify child has WorkflowCancelled event
    childEvents := self.store readEvents: childId fromSeq: 1
    childEventTypes := childEvents collect: [:e | e eventType]
    self assert: (childEventTypes includes: #WorkflowCancelled)

  // === CancellationError is an Error subclass ===
  testCancellationErrorIsErrorSubclass =>
    // Verify CancellationError can be caught with on:do:
    result := [
      CancellationError signal: "test cancel"
    ] on: CancellationError do: [:e | #caught]
    self assert: result equals: #caught

  // === Engine isCancelled: tracks cancellation state ===
  testEngineTracksCancellationState =>
    self assert: (self.engine isCancelled: "track-1") equals: false

    // Start and cancel a workflow
    self.engine
      startWorkflow: SlowWorkflow
      id: "track-1"
      args: #(2000)
    Erlang timer sleep: 500
    self.engine cancelWorkflow: "track-1"

    // Now it should be cancelled
    self assert: (self.engine isCancelled: "track-1") equals: true

    // Clear cancellation
    self.engine clearCancellation: "track-1"
    self assert: (self.engine isCancelled: "track-1") equals: false

  // === Child workflows with #abandon policy are not cancelled ===
  testAbandonPolicyChildNotCancelledByParent =>
    // Use a long sleep so both parent and child are running when we cancel
    self.engine
      startWorkflow: SlowWorkflow
      id: "abandon-parent-1"
      args: #(2000)
    // Wait for the parent's runner to start (engine is free with async timers)
    Erlang timer sleep: 500

    // Start a child with #abandon policy
    _childHandle := (self.engine withTimeout: 15000)
      startChildWorkflow: SlowWorkflow
      id: "abandon-child-1"
      args: #(2000)
      parentWorkflowId: "abandon-parent-1"
      options: #{#parentClosePolicy => #abandon}
    Erlang timer sleep: 500

    // Cancel the parent
    self.engine cancelWorkflow: "abandon-parent-1"
    Erlang timer sleep: 500

    // Parent should be cancelled
    parentExec := self.store getExecution: "abandon-parent-1"
    self assert: parentExec status equals: #cancelled

    // Child should still be running (abandon policy)
    childExec2 := self.store getExecution: "abandon-child-1"
    self assert: childExec2 status equals: #running
