/// BT-1499: BUnit tests for ExduraSupervisor and ExduraWorker.
///
/// Tests the supervision tree structure, rest_for_one strategy, and the
/// full ExduraWorker start: flow including running workflows through
/// the client.
TestCase subclass: ExduraSupervisorTest
  field: client = nil

  setUp =>
    [File deleteAll: "data"] on: Error do: [:e | nil]
    Erlang timer sleep: 200
    self

  tearDown =>
    self.client isNil
      ifFalse: [
        [self.client destroy] on: Error do: [:e | nil]
        [self.client stop] on: Error do: [:e | nil]
      ]
    self.client := nil
    [File deleteAll: "data"] on: Error do: [:e | nil]

  // ── Helpers ──

  /// Wait for a workflow to reach a terminal status (completed/failed/cancelled).
  /// Polls every 50ms up to the given timeout in milliseconds.
  awaitWorkflow: workflowId timeout: timeoutMs :: Integer =>
    deadline := Time nowMs + timeoutMs
    [true] whileTrue: [
      exec := self.client eventStore getExecution: workflowId
      (exec isNil not and: [
        exec status =:= #completed or: [
          exec status =:= #failed or: [exec status =:= #cancelled]
        ]
      ]) ifTrue: [^exec]
      Time nowMs >= deadline ifTrue: [self error: "Timed out waiting for {workflowId}"]
      Timer sleep: 50
    ]

  // === ExduraSupervisor class-side config ===
  testSupervisorStrategyIsRestForOne =>
    self assert: ExduraSupervisor strategy equals: #restForOne

  // === ExduraWorker boots supervision tree and runs workflows ===
  testWorkerBootsAndRunsWorkflows =>
    // Start worker with custom config
    self.client := ExduraWorker start: #{#maxConcurrentActivities => 25}
    self assert: self.client notNil
    self assert: self.client engine notNil
    self assert: self.client eventStore notNil

    // Verify the supervisor started all 4 children
    sup := self.client supervisor
    self assert: sup notNil
    self assert: sup count equals: 4
    self assert: (sup which: EventStore) notNil
    self assert: (sup which: ActivityWorkerPool) notNil
    self assert: (sup which: WorkflowEngine) notNil
    self assert: (sup which: TimerManager) notNil

    // Verify config was applied to the pool
    pool := self.client engine activityPool
    self assert: pool maxConcurrent equals: 25

    // Run a simple passthrough workflow through the supervised engine
    handle := self.client
      start: PassthroughWorkflow
      id: "sup-wf-1"
      args: #("supervised")
      taskQueue: "default"
      options: #{}
    result := handle result: 5000
    self assert: result equals: "supervised"

    // Run a two-activity workflow through the supervised engine
    self.client
      start: TwoActivityWorkflow
      id: "sup-wf-2"
      args: #(5)
      taskQueue: "default"
      options: #{}
    exec := self awaitWorkflow: "sup-wf-2" timeout: 10000
    self assert: exec notNil
    self assert: exec result equals: 20
