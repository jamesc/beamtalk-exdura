/// Metadata for a single execution of a workflow.
///
/// Tracks identity, status, and lifecycle timestamps. Stored in the
/// EventStore and updated as the workflow progresses through its states:
/// #running → #completed | #failed | #cancelled.
///
///   WorkflowExecution new: #{
///     #workflowId => "order-123",
///     #runId => "run-abc",
///     #workflowType => "OrderWorkflow",
///     #taskQueue => "default",
///     #startedAt => 1710000000
///   }
typed Value subclass: WorkflowExecution
  field: workflowId :: String = ""
  field: runId :: String = ""
  field: workflowType :: String = ""
  field: taskQueue :: String = ""
  field: args :: List = #()
  field: status :: Symbol = #running
  field: result :: Object | Nil = nil
  field: error :: String | Nil = nil
  field: parentWorkflowId :: String | Nil = nil
  field: startedAt :: Integer = 0
  field: closedAt :: Integer | Nil = nil
  field: searchAttributes :: Dictionary(String, Object) = #{}

  /// Display as WorkflowExecution(order-123 running)
  printString -> String => "WorkflowExecution({self workflowId} {self status})"
