/// Convenience entry point for booting the Exdura workflow engine.
///
/// Starts ExduraSupervisor, wires children together, applies
/// configuration, and returns a connected ExduraClient.
///
///   client := ExduraWorker start: #{#maxConcurrentActivities => 20}
///   handle := client start: OrderWorkflow id: "order-1"
///     args: #("data") taskQueue: "orders" options: #{}
///   result := handle result
typed Object subclass: ExduraWorker

  /// Boot the supervision tree and return a connected ExduraClient.
  ///
  ///   client := ExduraWorker start: #{#maxConcurrentActivities => 20}
  class start: config :: Dictionary -> ExduraClient =>
    sup := ExduraSupervisor supervise valueOrDo: [:e |
      self error: "Failed to start ExduraSupervisor: {e}"
    ]

    // Sibling wiring is handled by ExduraSupervisor class initialize:
    engine := (sup which: WorkflowEngine) valueOrDo: [:e |
      self error: "WorkflowEngine not found under ExduraSupervisor: {e}"
    ]
    store := (sup which: EventStore) valueOrDo: [:e |
      self error: "EventStore not found under ExduraSupervisor: {e}"
    ]
    pool := (sup which: ActivityWorkerPool) valueOrDo: [:e |
      self error: "ActivityWorkerPool not found under ExduraSupervisor: {e}"
    ]

    // Apply config
    maxActivities := config at: #maxConcurrentActivities ifAbsent: [10]
    pool setMaxConcurrent: maxActivities

    // Create client connected to the supervised engine
    client := ExduraClient spawnWith: #{#engine => engine, #eventStore => store}
    client setSupervisor: sup
    client
